{
  "name": "Embedded Kedi in Python docstrings",
  "scopeName": "source.kedi.embedded.python",
  "injectionSelector": "L:source.python",
  "patterns": [
    {
      "include": "#kedi-docstring"
    }
  ],
  "repository": {
    "kedi-docstring": {
      "name": "meta.embedded.block.kedi.python",
      "begin": "([rRuUbBfF]{0,2})(\"\"\"|''')(?=\\s*kedi\\b)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.string.python"
        },
        "2": {
          "name": "punctuation.definition.string.begin.python"
        }
      },
      "end": "\\2",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.python"
        }
      },
      "patterns": [
        {
          "name": "keyword.other.kedi.docstring.header",
          "match": "\\G\\s*kedi\\b"
        },
        {
          "include": "#kedi"
        }
      ]
    },
    "kedi": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#python-block"
        },
        {
          "include": "#directives"
        },
        {
          "include": "#declarations"
        },
        {
          "include": "#typed-placeholders"
        },
        {
          "include": "#substitutions"
        },
        {
          "include": "#inline-python"
        },
        {
          "include": "#operators"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.kedi",
          "begin": "^\\s*###\\s*$",
          "end": "^\\s*###\\s*$"
        },
        {
          "name": "comment.line.number-sign.kedi",
          "match": "#.*$"
        }
      ]
    },
    "python-block": {
      "name": "markup.fenced_code.block.python.kedi",
      "begin": "```",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.fenced.begin.kedi"
        }
      },
      "end": "```",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.fenced.end.kedi"
        }
      },
      "patterns": [
        {
          "include": "source.python"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "match": "^(\\s*)(>)(\\s*)(import|export|model|effort|system|mcp|settings|profile|use|case|data|test_data|metric|auto|optimize)\\b",
          "captures": {
            "2": {
              "name": "keyword.control.directive.kedi"
            },
            "4": {
              "name": "keyword.control.directive.kedi"
            }
          }
        },
        {
          "match": "^(\\s*)(>>)",
          "captures": {
            "2": {
              "name": "keyword.control.template.kedi"
            }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "^(\\s*)(@)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.operator.procedure.kedi"
            },
            "3": {
              "name": "entity.name.function.kedi"
            }
          }
        },
        {
          "match": "^(\\s*)(~)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": {
              "name": "keyword.operator.type.kedi"
            },
            "3": {
              "name": "entity.name.type.class.kedi"
            }
          }
        },
        {
          "match": "\\b(str|int|float|bool|list|dict|tuple|set|Any|Optional|Union|Literal)\\b",
          "name": "support.type.kedi"
        }
      ]
    },
    "typed-placeholders": {
      "patterns": [
        {
          "match": "(\\[)(\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(:)(\\s*)([^\\]\\n]+)(\\])",
          "captures": {
            "1": {
              "name": "keyword.operator.placeholder.begin.kedi"
            },
            "3": {
              "name": "variable.other.kedi"
            },
            "5": {
              "name": "keyword.operator.type-separator.kedi"
            },
            "7": {
              "name": "support.type.kedi"
            },
            "8": {
              "name": "keyword.operator.placeholder.end.kedi"
            }
          }
        },
        {
          "match": "(\\[)(\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(\\])",
          "captures": {
            "1": {
              "name": "keyword.operator.placeholder.begin.kedi"
            },
            "3": {
              "name": "variable.other.kedi"
            },
            "5": {
              "name": "keyword.operator.placeholder.end.kedi"
            }
          }
        }
      ]
    },
    "substitutions": {
      "patterns": [
        {
          "match": "(<)(\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(\\()",
          "captures": {
            "1": {
              "name": "keyword.operator.template-expression.begin.kedi"
            },
            "3": {
              "name": "entity.name.function.kedi"
            },
            "5": {
              "name": "keyword.operator.call.begin.kedi"
            }
          }
        },
        {
          "match": "(<)(\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(>)",
          "captures": {
            "1": {
              "name": "keyword.operator.template-expression.begin.kedi"
            },
            "3": {
              "name": "variable.other.kedi"
            },
            "5": {
              "name": "keyword.operator.template-expression.end.kedi"
            }
          }
        }
      ]
    },
    "inline-python": {
      "patterns": [
        {
          "name": "source.python.embedded.kedi",
          "match": "`[^`]*`"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "(->|=|:|,|\\(|\\)|\\[|\\]|<|>)",
          "name": "keyword.operator.kedi"
        }
      ]
    }
  }
}
